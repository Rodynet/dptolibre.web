<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DptoLibre - Registro y Activación Web</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- React & ReactDOM -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <!-- Babel -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        
        :root {
            --brand-blue: #0055DD;
            --brand-dark: #0A142F;
        }

        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #f8fafc;
            color: #1e293b;
        }

        .animate-in { animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .qr-shadow {
            box-shadow: 0 0 40px rgba(0, 85, 221, 0.15);
        }

        .admin-sidebar {
            background-color: var(--brand-dark);
        }

        .btn-social {
            @apply flex items-center justify-center gap-3 w-full py-3 px-4 border border-slate-200 rounded-xl font-bold text-sm transition-all hover:bg-slate-50 active:scale-[0.98];
        }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        const Icon = ({ name, size = 20, className = "" }) => {
            useEffect(() => { window.lucide && window.lucide.createIcons(); }, [name]);
            return <i data-lucide={name} style={{ width: size, height: size }} className={className}></i>;
        };

        function DptoLibreWeb() {
            // ESTADOS: landing, role_selection, app_download, final_dashboard
            const [step, setStep] = useState('landing');
            const [userRole, setUserRole] = useState(null); // 'inquilino', 'propietario', 'administrador'

            // --- VISTA 1: CREACIÓN DE USUARIO ---
            const LandingView = () => (
                <div className="min-h-screen flex items-center justify-center p-6 animate-in">
                    <div className="max-w-md w-full bg-white rounded-[2.5rem] shadow-2xl p-10 border border-slate-100">
                        <div className="flex flex-col items-center mb-10 text-[#0055DD]">
                            <svg width="48" viewBox="0 0 32 40" fill="none"><path d="M16 0L32 6.4V33.6L16 40V6.4L16 0Z" fill="#0055DD" fillOpacity="0.3"/><path d="M0 6.4L16 0V33.6L0 40V6.4Z" fill="#0055DD"/></svg>
                            <h1 className="text-2xl font-black mt-4 uppercase tracking-tighter">dpto <span className="font-light">libre</span></h1>
                        </div>

                        <div className="text-center mb-8">
                            <h2 className="text-xl font-bold text-slate-800">Crea tu cuenta</h2>
                            <p className="text-slate-400 text-sm mt-1">Elige tu método de acceso preferido</p>
                        </div>

                        <div className="space-y-3">
                            <button onClick={() => setStep('role_selection')} className="btn-social">
                                <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-1 .67-2.26 1.07-3.71 1.07-2.87 0-5.3-1.94-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.11c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.09H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.91l3.66-2.8z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.09l3.66 2.8c.86-2.59 3.29-4.51 6.16-4.51z" fill="#EA4335"/></svg>
                                Continuar con Google
                            </button>
                            <button onClick={() => setStep('role_selection')} className="btn-social bg-black text-white border-none hover:bg-slate-900">
                                <Icon name="apple" size={18} className="fill-white"/> Continuar con Apple
                            </button>
                            
                            <div className="flex items-center gap-4 py-4">
                                <div className="h-[1px] flex-1 bg-slate-100"></div>
                                <span className="text-[10px] font-black text-slate-300 uppercase tracking-widest leading-none">o con email</span>
                                <div className="h-[1px] flex-1 bg-slate-100"></div>
                            </div>

                            <div className="space-y-3">
                                <input type="email" placeholder="Tu correo electrónico" className="w-full bg-slate-50 border-none p-4 rounded-xl text-sm font-medium outline-none focus:ring-2 focus:ring-[#0055DD]" />
                                <button onClick={() => setStep('role_selection')} className="w-full bg-[#0055DD] text-white py-4 rounded-xl font-black text-xs uppercase tracking-widest shadow-xl shadow-blue-100">Registrarme</button>
                            </div>
                        </div>
                    </div>
                </div>
            );

            // --- VISTA 2: SELECCIÓN DE PERFIL ---
            const RoleSelectionView = () => (
                <div className="min-h-screen flex items-center justify-center p-6 animate-in">
                    <div className="max-w-2xl w-full bg-white rounded-[3rem] shadow-2xl p-12 text-center">
                        <h2 className="text-3xl font-black text-slate-800 tracking-tight leading-none mb-4">¿Cuál es tu rol?</h2>
                        <p className="text-slate-400 font-medium mb-12">Personalizaremos tu acceso según tu actividad.</p>
                        
                        <div className="grid grid-cols-3 gap-6">
                            {[
                                { id: 'inquilino', label: 'Inquilino', icon: 'user', desc: 'Busco alquilar.' },
                                { id: 'propietario', label: 'Propietario', icon: 'shield', desc: 'Tengo propiedades.' },
                                { id: 'administrador', label: 'Inmobiliaria', icon: 'building', desc: 'Gestiono activos.' }
                            ].map(role => (
                                <button 
                                    key={role.id}
                                    onClick={() => { setUserRole(role.id); setStep('app_download'); }}
                                    className="flex flex-col items-center gap-4 p-8 border-2 border-slate-50 rounded-[2.5rem] hover:border-[#0055DD] hover:bg-blue-50/30 transition-all group"
                                >
                                    <div className="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-300 group-hover:bg-[#0055DD] group-hover:text-white transition-all shadow-sm">
                                        <Icon name={role.icon} size={32} />
                                    </div>
                                    <div>
                                        <h4 className="font-black text-slate-800 uppercase text-xs tracking-widest">{role.label}</h4>
                                        <p className="text-[10px] text-slate-400 font-medium mt-1 uppercase">{role.desc}</p>
                                    </div>
                                </button>
                            ))}
                        </div>
                    </div>
                </div>
            );

            // --- VISTA 3: QR DESCARGA APP (HANDOVER) ---
            const AppDownloadView = () => (
                <div className="min-h-screen flex items-center justify-center p-6 animate-in">
                    <div className="max-w-lg w-full bg-white rounded-[3rem] shadow-2xl p-12 text-center border border-slate-100">
                        <div className="w-20 h-20 bg-indigo-50 text-indigo-600 rounded-[2rem] flex items-center justify-center mx-auto mb-8 shadow-inner">
                            <Icon name="smartphone" size={40} />
                        </div>
                        <h2 className="text-3xl font-black text-slate-800 tracking-tight leading-none mb-6">Activa tu Perfil</h2>
                        <p className="text-slate-500 font-medium leading-relaxed mb-10 px-4">
                            Por seguridad, la validación biométrica y de identidad se realiza exclusivamente a través de la App móvil.
                        </p>
                        
                        <div className="inline-block p-6 bg-white rounded-[2rem] qr-shadow border border-slate-50 mb-10">
                            <div className="w-48 h-48 bg-slate-900 rounded-2xl flex items-center justify-center">
                                <Icon name="qr-code" size={140} className="text-white" />
                            </div>
                            <p className="text-[10px] font-black text-slate-400 uppercase mt-4 tracking-[0.2em]">Escanea para descargar</p>
                        </div>

                        <div className="space-y-4">
                            <p className="text-xs text-slate-400 font-bold italic animate-pulse">Esperando activación desde el celular...</p>
                            {/* Botón de simulación para que el usuario pueda avanzar en el prototipo */}
                            <button 
                                onClick={() => setStep('final_dashboard')}
                                className="text-[#0055DD] font-black text-[10px] uppercase tracking-widest border-b-2 border-[#0055DD]/20 hover:border-[#0055DD] transition-all"
                            >
                                Simular fin de activación
                            </button>
                        </div>
                    </div>
                </div>
            );

            // --- VISTA 4: DASHBOARDS FINALES (CONDICIONALES) ---
            const FinalDashboard = () => {
                // Caso Inquilino o Propietario
                if (userRole !== 'administrador') {
                    return (
                        <div className="min-h-screen flex items-center justify-center p-6 animate-in bg-[#F0F2F6]">
                            <div className="max-w-xl w-full bg-white rounded-[3rem] shadow-2xl p-12 text-center relative overflow-hidden">
                                <Icon name="shield-check" size={200} className="absolute -right-20 -bottom-20 text-emerald-500/5" />
                                <div className="w-20 h-20 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-8 border-4 border-emerald-100">
                                    <Icon name="check" size={40} strokeWidth={4} />
                                </div>
                                <h2 className="text-3xl font-black text-slate-800 tracking-tight leading-none mb-6">¡Perfil Activado!</h2>
                                <p className="text-slate-500 font-medium leading-relaxed mb-10 px-8">
                                    Marcos, tu pasaporte digital ya está validado. Como <b>{userRole === 'inquilino' ? 'Inquilino' : 'Propietario'}</b>, tu centro de operaciones es la App móvil.
                                </p>
                                <div className="bg-slate-50 p-6 rounded-[2rem] border border-slate-100 text-left mb-8">
                                    <h4 className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Desde la App podrás:</h4>
                                    <ul className="space-y-3">
                                        <li className="flex items-center gap-3 text-sm font-bold text-slate-700">
                                            <div className="w-2 h-2 bg-emerald-500 rounded-full"></div> 
                                            {userRole === 'inquilino' ? 'Gestionar tu blindaje y racha' : 'Cobrar tus rentas en tiempo real'}
                                        </li>
                                        <li className="flex items-center gap-3 text-sm font-bold text-slate-700">
                                            <div className="w-2 h-2 bg-emerald-500 rounded-full"></div> 
                                            Visualizar recibos legales de ARCA
                                        </li>
                                        <li className="flex items-center gap-3 text-sm font-bold text-slate-700">
                                            <div className="w-2 h-2 bg-emerald-500 rounded-full"></div> 
                                            Reportar y autorizar tickets de soporte
                                        </li>
                                    </ul>
                                </div>
                                <p className="text-xs text-[#0055DD] font-black uppercase tracking-widest">Abre DptoLibre en tu celular para continuar.</p>
                            </div>
                        </div>
                    );
                }

                // Caso Administrador (Web Console)
                return (
                    <div className="flex h-screen w-full animate-in bg-slate-50">
                        {/* Sidebar Simplificado */}
                        <aside className="w-64 admin-sidebar text-white flex flex-col p-6 shadow-2xl">
                            <div className="flex items-center gap-3 mb-10">
                                <div className="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center font-black">B</div>
                                <span className="font-black tracking-tighter text-xl leading-none">BLINDATO</span>
                            </div>
                            <nav className="space-y-2 flex-1">
                                <div className="p-3 bg-indigo-600 rounded-xl font-bold flex items-center gap-3"><Icon name="layout-dashboard" size={18}/> Dashboard</div>
                                <div className="p-3 text-slate-400 hover:text-white font-bold flex items-center gap-3"><Icon name="building" size={18}/> Propiedades</div>
                                <div className="p-3 text-slate-400 hover:text-white font-bold flex items-center gap-3"><Icon name="users" size={18}/> Inquilinos</div>
                                <div className="p-3 text-slate-400 hover:text-white font-bold flex items-center gap-3"><Icon name="wallet" size={18}/> Tesorería</div>
                            </nav>
                            <button onClick={() => setStep('landing')} className="mt-auto p-4 text-slate-500 hover:text-white text-xs font-black uppercase text-center border-t border-white/10 pt-6">Cerrar Sesión</button>
                        </aside>

                        {/* Main Content */}
                        <main className="flex-1 overflow-y-auto">
                            <header className="bg-white p-8 border-b flex justify-between items-center sticky top-0 z-10 shadow-sm">
                                <div>
                                    <h2 className="text-2xl font-black text-slate-800">Bienvenido, Admin</h2>
                                    <p className="text-slate-400 text-sm font-medium italic">Consola de orquestación inmobiliaria</p>
                                </div>
                                <div className="flex items-center gap-6">
                                    <div className="relative">
                                        <Icon name="search" className="absolute left-3 top-2.5 text-slate-300" size={18}/>
                                        <input type="text" placeholder="Buscador universal..." className="pl-10 pr-4 py-2 bg-slate-100 border-none rounded-xl text-sm w-80" />
                                    </div>
                                    <Icon name="bell" size={24} className="text-slate-300" />
                                </div>
                            </header>

                            <div className="p-8 space-y-10">
                                {/* KPIs Cards */}
                                <div className="grid grid-cols-3 gap-6">
                                    <div className="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
                                        <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Recaudación Total</p>
                                        <p className="text-3xl font-black text-slate-800">$12.5M</p>
                                        <div className="mt-2 text-emerald-500 text-xs font-bold flex items-center gap-1"><Icon name="trending-up" size={14}/> +8% vs mes anterior</div>
                                    </div>
                                    <div className="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
                                        <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Honorarios Listos</p>
                                        <p className="text-3xl font-black text-indigo-600">$840.5k</p>
                                        <button className="mt-2 text-[#0055DD] text-[10px] font-black uppercase border-b border-[#0055DD]/20">Invertir Saldo</button>
                                    </div>
                                    <div className="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
                                        <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Salud de Cartera</p>
                                        <p className="text-3xl font-black text-emerald-600">94.2%</p>
                                        <p className="mt-2 text-slate-400 text-xs font-medium">3 alertas de riesgo activas</p>
                                    </div>
                                </div>

                                {/* Secciones de interés */}
                                <div className="bg-white rounded-[2.5rem] p-10 border border-slate-100 shadow-sm text-center">
                                     <div className="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-6 text-slate-200">
                                        <Icon name="plus" size={32} />
                                     </div>
                                     <h3 className="text-xl font-black text-slate-800 uppercase tracking-tight">Comenzar Gestión</h3>
                                     <p className="text-slate-400 text-sm mb-8">No tienes activos cargados todavía.</p>
                                     <button className="bg-indigo-600 text-white px-10 py-4 rounded-2xl font-black text-xs uppercase tracking-widest shadow-xl shadow-indigo-100 active:scale-95 transition-all">
                                        Cargar Primera Propiedad
                                     </button>
                                </div>
                            </div>
                        </main>
                    </div>
                );
            };

            return (
                <div className="min-h-screen w-full relative">
                    {step === 'landing' && <LandingView />}
                    {step === 'role_selection' && <RoleSelectionView />}
                    {step === 'app_download' && <AppDownloadView />}
                    {step === 'final_dashboard' && <FinalDashboard />}
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<DptoLibreWeb />);
    </script>
</body>
</html>
